# ─── Bot ─────────────────────────────────────────────────────────────────────
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
BOT_USERNAME=vpn_nexora_bot
BOT_ADMINS=YOUR_TELEGRAM_ID
BOT_DEV_ID=YOUR_TELEGRAM_ID
BOT_DOMAIN=localhost
BOT_PORT=8090
# true = local dev (clears any production webhook on startup)
# false = production webhook mode
BOT_USE_POLLING=true

# ─── 3X-UI Panel ─────────────────────────────────────────────────────────────
XUI_HOST=https://p.nexoranode.xyz:2087
XUI_PATH=/CC6AiFGmYY4ZWVRf08
XUI_USERNAME=YOUR_PANEL_USERNAME
XUI_PASSWORD=YOUR_PANEL_PASSWORD
XUI_TOKEN=
XUI_SUB_BASE_URL=https://s.nexoranode.xyz:2096/s/
# Optional — leave empty to auto-use all enabled panel inbounds
# XUI_INBOUND_FILTER=
XUI_START_AFTER_FIRST_USE=true
XUI_DEFAULT_DURATION_DAYS=30

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////app/data/nexorabot.sqlite3
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://nexora:CHANGE_ME@postgres:5432/nexorabot

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB_NAME=0
REDIS_USERNAME=
REDIS_PASSWORD=

# ─── Payment ─────────────────────────────────────────────────────────────────
CARD_NUMBER=6037-XXXX-XXXX-XXXX
CARD_OWNER=نام صاحب کارت
CARD_BANK=ملت
ADMIN_CHAT_ID=YOUR_ADMIN_TELEGRAM_ID
SUPPORT_USERNAME=nexorasupport

# ─── Plans ────────────────────────────────────────────────────────────────────
# PLANS_FILE=app/data/plans.json
QUANTITY_MAX=20

# ─── Referral bonuses (Toman) ────────────────────────────────────────────────
REFERRAL_BONUS_TOMAN=8000
REFERRAL_FRIEND_BONUS_TOMAN=5000

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=%(asctime)s | %(name)s | %(levelname)s | %(message)s
