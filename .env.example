# ─── Bot ─────────────────────────────────────────────────────────────────────
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
BOT_USERNAME=nc_vpn_bot
BOT_ADMINS=YOUR_TELEGRAM_ID
# Super admin (BOT_DEV_ID) sees full receipt + details after approve/reject; other admins see summary only.
BOT_DEV_ID=YOUR_TELEGRAM_ID
BOT_DOMAIN=localhost
BOT_PORT=8090
# true = local dev (clears any production webhook on startup)
# false = production webhook mode
BOT_USE_POLLING=true

# Mandatory channels before using the bot (comma-separated).
# Format: @channel  or  Display Name|@channel  or  Display Name|https://t.me/channel
# Bot must be admin in each channel to verify membership.
# Mandatory channel — bot must be admin in @nc_vpn_shop to verify joins
REQUIRED_CHANNELS=NC Network|@nc_vpn_shop
CHANNEL_GATE_ENABLED=true

# ─── 3X-UI / Xray panel — https://p.nexoranode.xyz:2057/... ─────────────────
# Same server + Docker: use https://127.0.0.1:2057 (auto → host.docker.internal)
# Or public URL: https://p.nexoranode.xyz:2057
# Admin manage UI is separate: https://manage.nexoranode.xyz:2053
XUI_HOST=https://p.nexoranode.xyz:2057
XUI_PATH=/F9Ax1FO5Oh7yWLk8Ww
XUI_USERNAME=YOUR_PANEL_USERNAME
XUI_PASSWORD=YOUR_PANEL_PASSWORD
XUI_TOKEN=
# Subscription link base — MUST end with /s/ (profile page in browser, not YAML download).
# Bot builds links as: {XUI_SUB_BASE_URL}{subscription_id}
# Example: https://sub.manchesterchocolates.ir/s/abc123...
XUI_SUB_BASE_URL=https://sub.manchesterchocolates.ir/s/
# Optional — leave empty to auto-use all enabled panel inbounds
# XUI_INBOUND_FILTER=
XUI_START_AFTER_FIRST_USE=true
XUI_DEFAULT_DURATION_DAYS=30

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////app/data/nexorabot.sqlite3
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://nexora:CHANGE_ME@postgres:5432/nexorabot

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB_NAME=0
REDIS_USERNAME=
REDIS_PASSWORD=

# ─── Payment ─────────────────────────────────────────────────────────────────
CARD_NUMBER=6037-XXXX-XXXX-XXXX
CARD_OWNER=نام صاحب کارت
CARD_BANK=ملت
ADMIN_CHAT_ID=YOUR_ADMIN_TELEGRAM_ID
SUPPORT_USERNAME=ncvpn_support

# ─── Plans ────────────────────────────────────────────────────────────────────
# PLANS_FILE=app/data/plans.json
QUANTITY_MAX=20

# ─── Referral bonuses (Toman) ────────────────────────────────────────────────
REFERRAL_BONUS_TOMAN=8000
REFERRAL_FRIEND_BONUS_TOMAN=5000
# Ready-to-forward invite post image (optional). Also auto-detects:
#   app/data/referral_post.jpg  OR  app/bot/assets/referral_post.jpg
# REFERRAL_POST_IMAGE=/app/data/referral_post.jpg

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=%(asctime)s | %(name)s | %(levelname)s | %(message)s
