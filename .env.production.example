# ─── Bot ─────────────────────────────────────────────────────────────────────
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
BOT_ADMINS=YOUR_TELEGRAM_ID
BOT_DEV_ID=YOUR_TELEGRAM_ID

# Public URL for Telegram webhook (HTTPS required, port 8443 because 443 = Reality)
BOT_DOMAIN=bot.nexoranode.xyz:8443
BOT_USE_HTTPS=true

# Internal bot port inside Docker — ALWAYS 8090, never 8443
BOT_PORT=8090
BOT_USE_POLLING=false

# Nginx host ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=8443

# ─── 3X-UI Panel ─────────────────────────────────────────────────────────────
XUI_HOST=https://p.nexoranode.xyz:2087
XUI_PATH=/CC6AiFGmYY4ZWVRf08
XUI_USERNAME=YOUR_PANEL_USERNAME
XUI_PASSWORD=YOUR_PANEL_PASSWORD
XUI_TOKEN=
XUI_SUB_BASE_URL=https://s.nexoranode.xyz:2096/s/
XUI_WS_INBOUND_NAME=NX-WS
XUI_REALITY_INBOUND_NAME=NX-Reality
XUI_START_AFTER_FIRST_USE=true
XUI_DEFAULT_DURATION_DAYS=30

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Host must be Docker service name "postgres", not container name
DATABASE_URL=postgresql+asyncpg://nexora:CHANGE_ME@postgres:5432/nexorabot
POSTGRES_DB=nexorabot
POSTGRES_USER=nexora
POSTGRES_PASSWORD=CHANGE_ME

# ─── Redis ────────────────────────────────────────────────────────────────────
# Host must be Docker service name "redis"
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB_NAME=0
REDIS_USERNAME=
REDIS_PASSWORD=

# ─── Payment ─────────────────────────────────────────────────────────────────
CARD_NUMBER=6037-XXXX-XXXX-XXXX
CARD_OWNER=نام صاحب کارت
ADMIN_CHAT_ID=YOUR_TELEGRAM_ID
AGENCY_ADMIN_CHAT_ID=YOUR_TELEGRAM_ID
SUPPORT_USERNAME=@nexorasupport

# ─── Pricing (Toman) ─────────────────────────────────────────────────────────
PRICE_BRONZE=170000
PRICE_SILVER=450000
PRICE_GOLD=650000
PRICE_DIAMOND=1100000
PRICE_BULK_10GB=170000
PRICE_BULK_30GB=450000
PRICE_BULK_50GB=650000
PRICE_BULK_100GB=1100000

# ─── Referral / Trial ────────────────────────────────────────────────────────
REFERRAL_BONUS_MB=500
REFERRAL_FRIEND_BONUS_MB=200
FREE_TRIAL_MB=100
FREE_TRIAL_DAYS=1

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(name)s | %(levelname)s | %(message)s
