# ─── Bot ─────────────────────────────────────────────────────────────────────
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
BOT_ADMINS=YOUR_TELEGRAM_ID,ANOTHER_ADMIN_ID
BOT_DEV_ID=YOUR_TELEGRAM_ID
BOT_DOMAIN=bot.nexoranode.xyz
BOT_USE_HTTPS=false
BOT_PORT=8090
BOT_USE_POLLING=false

# Nginx: use port 80 for HTTP webhook (443 is used by Reality)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=8443

# ─── 3X-UI Panel ─────────────────────────────────────────────────────────────
XUI_HOST=https://p.nexoranode.xyz:2087
XUI_PATH=/CC6AiFGmYY4ZWVRf08
XUI_USERNAME=YOUR_PANEL_USERNAME
XUI_PASSWORD=YOUR_PANEL_PASSWORD
XUI_TOKEN=
XUI_SUB_BASE_URL=https://s.nexoranode.xyz:2096/s/
XUI_WS_INBOUND_NAME=NX-WS
XUI_REALITY_INBOUND_NAME=NX-Reality

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nexora:CHANGE_ME@nexoranode-postgres:5432/nexorabot
POSTGRES_DB=nexorabot
POSTGRES_USER=nexora
POSTGRES_PASSWORD=CHANGE_ME

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=nexoranode-redis
REDIS_PORT=6379
REDIS_DB_NAME=0
REDIS_USERNAME=
REDIS_PASSWORD=

# ─── Payment ─────────────────────────────────────────────────────────────────
CARD_NUMBER=6037-XXXX-XXXX-XXXX
CARD_OWNER=نام صاحب کارت
ADMIN_CHAT_ID=YOUR_TELEGRAM_ID
AGENCY_ADMIN_CHAT_ID=YOUR_TELEGRAM_ID
SUPPORT_USERNAME=@nexorasupport

# ─── Pricing (Toman) ─────────────────────────────────────────────────────────
PRICE_1_MONTH_10GB=80000
PRICE_1_MONTH_30GB=120000
PRICE_1_MONTH_50GB=180000
PRICE_3_MONTH_30GB=300000
PRICE_3_MONTH_50GB=450000
PRICE_6_MONTH_50GB=800000
PRICE_BULK_30GB=90000
PRICE_BULK_50GB=140000
PRICE_BULK_100GB=250000

# ─── Referral / Trial ────────────────────────────────────────────────────────
REFERRAL_BONUS_MB=500
REFERRAL_FRIEND_BONUS_MB=200
FREE_TRIAL_MB=100
FREE_TRIAL_DAYS=1

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(name)s | %(levelname)s | %(message)s
