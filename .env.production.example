# ─── Bot ─────────────────────────────────────────────────────────────────────
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
BOT_USERNAME=nc_vpn_bot
BOT_ADMINS=YOUR_TELEGRAM_ID
BOT_DEV_ID=YOUR_TELEGRAM_ID

# Public URL for Telegram webhook — HTTPS on 8443 (443 is used by Reality).
# Requires SSL certs: bash deploy/setup-ssl.sh
BOT_DOMAIN=bot.nexoranode.xyz:8443
BOT_USE_HTTPS=true

# Internal bot port inside Docker — ALWAYS 8090, never 8443
BOT_PORT=8090
BOT_USE_POLLING=false

# Mandatory channel — users must join before using the bot (admins included).
# Bot must be admin in the channel to verify membership (getChatMember).
# REQUIRED_CHANNELS=Label|@username  or  @username1,@username2
REQUIRED_CHANNELS=NC Network|@nc_vpn_shop
CHANNEL_GATE_ENABLED=true

# Nginx host ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=8443

# ─── 3X-UI / Xray panel — https://p.nexoranode.xyz:2057/... ─────────────────
# Same server + Docker: https://127.0.0.1:2057 works (rewritten to host.docker.internal)
# Or use public URL: https://p.nexoranode.xyz:2057
# Admin manage UI: https://manage.nexoranode.xyz:2053
XUI_HOST=https://p.nexoranode.xyz:2057
XUI_PATH=/F9Ax1FO5Oh7yWLk8Ww
XUI_USERNAME=YOUR_PANEL_USERNAME
XUI_PASSWORD=YOUR_PANEL_PASSWORD
# Recommended: API token from Panel → Settings → Security → API Token
# Avoids cookie login (often blocked with HTTP 403 from server IPs).
XUI_TOKEN=
XUI_SUB_BASE_URL=https://sub.manchesterchocolates.ir/s/
# New purchases use /clash/ (Iran bypass). Leave empty to auto-derive from /s/ → /clash/
# Requires 3x-ui Panel → Settings → Subscription → Enable Clash/Mihomo subscription (subClashEnable)
# and subClashPath=/clash/ (default). Without this, /clash/{id} returns 404 while /s/{id} works.
XUI_SUB_CLASH_BASE_URL=https://sub.manchesterchocolates.ir/clash/
# Optional: comma-separated inbound remarks to limit attachment.
# Leave empty = ALL enabled inbounds (🇩🇪 CDN + every direct node).
# XUI_INBOUND_FILTER=🇩🇪 NX AC,🇵🇱 PL-N1
XUI_START_AFTER_FIRST_USE=true
XUI_DEFAULT_DURATION_DAYS=30

# Direct nodes pull clients from panel via watcher (~1s). Do NOT enable SSH sync from Germany.
NODE_SYNC_ENABLED=false
# Shared secret: bot bumps Redis on purchase; nodes poll GET /internal/node-sync/v (same value as BOT_SYNC_TOKEN on nodes).
NODE_SYNC_TRIGGER_TOKEN=CHANGE_ME_RANDOM_HEX
NODE_SSH_USER=root
NODE_SSH_PORT=22
# Optional explicit key (default: use keys from mounted /root/.ssh)
# NODE_SSH_IDENTITY=/root/.ssh/id_ed25519

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nexora:CHANGE_ME@postgres:5432/nexorabot
POSTGRES_DB=nexorabot
POSTGRES_USER=nexora
POSTGRES_PASSWORD=CHANGE_ME

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB_NAME=0
REDIS_USERNAME=
REDIS_PASSWORD=

# ─── Payment ─────────────────────────────────────────────────────────────────
CARD_NUMBER=6037-XXXX-XXXX-XXXX
CARD_OWNER=NC VPN
CARD_BANK=ملت
ADMIN_CHAT_ID=YOUR_TELEGRAM_ID
SUPPORT_USERNAME=ncvpn_support

# ─── Live data (outside git — edited by admin panel) ─────────────────────────
# Run once on server: bash deploy/setup-data-dir.sh
BOT_DATA_HOST=/opt/nexoranode-data
PLANS_FILE=/app/data/plans.json

# Max quantity allowed in a single purchase
QUANTITY_MAX=20

# ─── Referral bonuses (Toman) ────────────────────────────────────────────────
REFERRAL_BONUS_TOMAN=8000
REFERRAL_FRIEND_BONUS_TOMAN=5000
# Invite forward-post image — put file on data volume (no rebuild needed):
#   /opt/nexoranode-data/referral_post.jpg
# REFERRAL_POST_IMAGE=/app/data/referral_post.jpg

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(name)s | %(levelname)s | %(message)s

# ─── Docker network (shared with admin panel — MUST match panel .env) ───────
DOCKER_NETWORK=deploy_nexora_net
